// generator と datasource の設定
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  // url      = env("DATABASE_URL")
}

/// デバイス情報管理テーブル
model Device {
  id             String   @id @default(uuid())
  macAddress     String   @unique @map("mac_address")
  ipAddress      String   @map("ip_address")
  name           String
  collectMetrics Boolean  @default(false) @map("collect_metrics")
  registeredAt   DateTime @map("registered_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // 型定義の名称に合わせたリレーションフィールド
  envLog        EnvironmentLog[]
  IRSensorValue IrSensorValue[]

  @@map("devices")
}

/// 環境ログ（センサーデータ）管理テーブル
model EnvironmentLog {
  id             Int      @id @default(autoincrement())
  deviceId       String   @map("device_id")
  temperatureSht Float    @map("temperature_sht")
  humidity       Float
  pressure       Float
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Deviceモデルへの参照
  device Device @relation(fields: [deviceId], references: [id])

  @@map("environment_logs")
}

/// 赤外線センサー値管理テーブル
model IrSensorValue {
  id        Int      @id @default(autoincrement())
  deviceId  String   @map("device_id")
  name      String
  data      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Deviceモデルへの参照
  device Device @relation(fields: [deviceId], references: [id])

  @@map("ir_sensor_values")
}
