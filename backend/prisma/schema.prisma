// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

/// デバイス情報管理テーブル
model Device {
  id               Int              @id @default(autoincrement())
  mac_address      String           @unique
  ip_address       String
  name             String
  location         String?          @db.Text
  collect_metrics  Boolean          @default(false)
  registered_at    DateTime
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt

  // リレーション定義
  environment_logs EnvironmentLog[]
  ir_sensor_values IrSensorValue[]

  @@map("devices")
}

/// 環境ログ（センサーデータ）管理テーブル
model EnvironmentLog {
  id              Int      @id @default(autoincrement())
  device_id       Int
  temperature_sht Float
  humidity        Float
  temperature_qmp Float
  pressure        Float
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Deviceモデルへの参照
  device          Device   @relation(fields: [device_id], references: [id])

  @@map("environment_logs")
}

/// 赤外線センサー値管理テーブル
model IrSensorValue {
  id         Int      @id @default(autoincrement())
  device_id  Int
  name       String
  data       String   @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Deviceモデルへの参照
  device     Device   @relation(fields: [device_id], references: [id])

  @@map("ir_sensor_values")
}
